{
  "private": true,
  "name": "@jsonhero/jsonhero-web",
  "description": "A beautiful JSON viewer for the web",
  "license": "apache-2.0",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run build:css && npm run build:search && react-router build && npm run build:worker",
    "build:css": "tailwindcss -i ./styles/tailwind.css -o ./app/tailwind.css --minify",
    "build:worker": "esbuild --define:process.env.NODE_ENV='\"production\"' --minify --bundle --format=esm --sourcemap --outdir=dist ./worker",
    "build:worker:analyze": "esbuild --define:process.env.NODE_ENV='\"production\"' --minify --bundle --format=esm --sourcemap --metafile=meta.json --outdir=dist ./worker",
    "build:visualize": "npm run clean && npm run build && npm run build:worker:analyze && esbuild-visualizer --metadata ./meta.json --exclude *.png",
    "build:search": "esbuild ./app/entry.worker.ts --outfile=./public/entry.worker.js --bundle --format=esm --define:process.env.NODE_ENV='\"production\"'",
    "dev:search": "esbuild ./app/entry.worker.ts --outfile=./public/entry.worker.js --bundle --format=esm --define:process.env.NODE_ENV='\"development\"' --watch",
    "dev:worker": "esbuild --define:process.env.NODE_ENV='\"development\"' --bundle --format=esm --sourcemap --outdir=dist ./worker --watch",
    "start:worker": "wrangler dev --config wrangler.toml --assets build/client",
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:search\" \"react-router dev --host 127.0.0.1 --port 3000 --strictPort\"",
    "dev:css": "tailwindcss -i ./styles/tailwind.css -o ./app/tailwind.css --watch",
    "start": "npm run dev",
    "start:worker:e2e": "wrangler dev --config wrangler.toml --port 8788 --assets build/client",
    "start:e2e": "concurrently \"npm run dev:css\" \"npm run dev:search\" \"react-router dev --host 127.0.0.1 --port 8788 --strictPort\"",
    "deploy": "npm run build && wrangler publish",
    "deploy:production": "npm run build && wrangler publish --env production",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "./tests/e2e/run-e2e.sh",
    "build:types": "react-router typegen && tsc",
    "build:types:watch": "tsc --watch",
    "lint": "npm run build:types"
  },
  "dependencies": {
    "@apihero/fetch": "^0.1.0",
    "@codemirror/lang-json": "^0.19.1",
    "@codemirror/rangeset": "^0.19.6",
    "@heroicons/react": "^1.0.5",
    "@js-temporal/polyfill": "^0.3.0",
    "@jsonhero/fuzzy-json-search": "^0.2.0",
    "@jsonhero/json-infer-types": "^1.2.x",
    "@jsonhero/json-schema-fns": "^0.0.1",
    "@jsonhero/path": "^1.0.17",
    "@jsonhero/schema-infer": "^0.1.x",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@react-router/cloudflare": "^7.14.1",
    "@swan-io/boxed": "^0.2.1",
    "@uiw/react-codemirror": "^4.3.3",
    "@xmldom/xmldom": "^0.9.9",
    "clsx": "^1.1.1",
    "color": "^4.2.1",
    "downshift": "^6.1.7",
    "fathom-client": "^3.4.1",
    "framer-motion": "^6.2.4",
    "json-source-map": "^0.6.1",
    "jwt-decode": "^3.1.2",
    "nanoid": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^11.4.2",
    "react-hotkeys-hook": "^3.4.4",
    "react-use-intercom": "^2.0.0",
    "react-virtual": "^2.10.4",
    "react-router": "^7.14.1",
    "tailwindcss-radix": "^1.6.0",
    "tiny-invariant": "^1.2.0",
    "ts-pattern": "^3.3.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260417.1",
    "@mdx-js/rollup": "^3.1.1",
    "@react-router/dev": "^7.14.1",
    "@react-router/fs-routes": "^7.14.1",
    "@react-router/serve": "^7.14.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/color": "^3.0.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/ua-parser-js": "^0.7.36",
    "@playwright/test": "^1.55.0",
    "concurrently": "^7.0.0",
    "esbuild-visualizer": "^0.3.1",
    "jest": "^29.7.0",
    "miniflare": "^4.20260415.0",
    "patch-package": "^8.0.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "wrangler": "^4.83.0"
  },
  "overrides": {
    "@vanilla-extract/integration": "^8.0.10",
    "braces": "^3.0.3",
    "picomatch": "^2.3.2",
    "minimatch": "^3.1.4",
    "tar": "^7.5.13"
  },
  "engines": {
    "node": ">=14"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "moduleNameMapper": {
      "^~/(.*)$": "<rootDir>/app/$1",
      "^lodash-es$": "lodash"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.json"
      }
    },
    "globalSetup": "./tests/setup.js"
  },
  "sideEffects": false,
  "main": "dist/worker.js"
}
